{
  "name": "sdlc-artifact-factory",
  "version": "0.1.0",
  "description": "Drives any product through its full SDLC lifecycle and emits reviewable artifacts at every phase. Enforces DDD, TDD, BDD, SOLID, and event-driven patterns across all generated artifacts.",
  "author": "shafibabar",

  "commands": [
    { "name": "sdlc-start",       "file": ".claude/commands/sdlc-start.md",       "description": "Initialise a new product run via interactive questionnaire" },
    { "name": "sdlc-next",        "file": ".claude/commands/sdlc-next.md",        "description": "Advance to the next phase after DoD check and human approval" },
    { "name": "sdlc-status",      "file": ".claude/commands/sdlc-status.md",      "description": "Show current phase, artifacts produced, DoD gaps, and warnings" },
    { "name": "sdlc-phase",       "file": ".claude/commands/sdlc-phase.md",       "description": "Jump to a specific phase (for mid-flight pickup or re-runs)" },
    { "name": "sdlc-artifact",    "file": ".claude/commands/sdlc-artifact.md",    "description": "Invoke a specific skill to generate a named artifact" },
    { "name": "sdlc-review",      "file": ".claude/commands/sdlc-review.md",      "description": "Trigger methodology compliance review of a phase or artifact" },
    { "name": "sdlc-glossary",    "file": ".claude/commands/sdlc-glossary.md",    "description": "View, search, or extend the ubiquitous language glossary" },
    { "name": "sdlc-adr",         "file": ".claude/commands/sdlc-adr.md",         "description": "Open a new Architecture Decision Record" },
    { "name": "sdlc-event-storm", "file": ".claude/commands/sdlc-event-storm.md", "description": "Initiate the Event Storming facilitation session" },
    { "name": "sdlc-story",       "file": ".claude/commands/sdlc-story.md",       "description": "Generate a user story from a named epic" },
    { "name": "sdlc-threat-model","file": ".claude/commands/sdlc-threat-model.md","description": "Run STRIDE threat model for the system or a specific service" },
    { "name": "sdlc-compliance",  "file": ".claude/commands/sdlc-compliance.md",  "description": "Run compliance assessment for a named framework" },
    { "name": "sdlc-repo-map",    "file": ".claude/commands/sdlc-repo-map.md",    "description": "Display and update the Bounded Context to repo mapping" },
    { "name": "sdlc-handoff",     "file": ".claude/commands/sdlc-handoff.md",     "description": "Generate a phase handoff summary document" },
    { "name": "sdlc-report",      "file": ".claude/commands/sdlc-report.md",      "description": "Generate a named cross-phase or single-phase report" }
  ],

