  "agents": [
    { "name": "event-storming-facilitator", "description": "Facilitates Event Storming sessions; produces domain events, commands, aggregates, policies, read models, and bounded context map" },
    { "name": "domain-modeler",             "description": "Deep DDD work per bounded context: aggregate invariants, value objects, domain service boundaries" },
    { "name": "security-reviewer",          "description": "STRIDE threat modelling, OWASP review, Zero Trust architecture assessment, compliance gap analysis" },
    { "name": "architecture-reviewer",      "description": "Reviews full architecture against NFRs, ADRs, and patterns; flags conflicts and gaps" },
    { "name": "backlog-refiner",            "description": "Refines epics into well-formed user stories with BDD-ready acceptance criteria and example maps" },
    { "name": "compliance-assessor",        "description": "Maps architecture and controls against compliance framework clauses; produces gap analysis and evidence packages" },
    { "name": "code-reviewer",             "description": "Reviews generated implementation artifacts for SOLID adherence, coding standards, and testability" },
    { "name": "test-strategy-advisor",      "description": "Designs the test pyramid and overall test strategy given the architecture, bounded contexts, and NFRs" },
    { "name": "ux-strategist",             "description": "Designs user flows, information architecture, and interaction patterns from personas and story maps" },
    { "name": "platform-engineer",         "description": "Designs deployment architecture, CI/CD pipelines, IaC templates, and operational runbooks" }
  ],

  "hooks": [
    { "name": "pre-phase-advance",       "event": "PreToolCall", "description": "DoD check before /sdlc-next; emits advisory; requires acknowledgment of gaps" },
    { "name": "post-artifact-created",   "event": "PostToolCall", "description": "Scans new artifact for glossary drift and methodology compliance" },
    { "name": "pre-event-storming",      "event": "PreToolCall", "description": "Validates domain context and FRD are sufficient before Event Storming" },
    { "name": "pre-implement",           "event": "PreToolCall", "description": "Confirms TDD spec exists before any code generation skill runs" },
    { "name": "pre-code-generation",     "event": "PreToolCall", "description": "Confirms coding standards and repo structure exist before service-skeleton" },
    { "name": "pre-deploy",              "event": "PreToolCall", "description": "Confirms quality reports and threat model exist before deploy skills run" },
    { "name": "pre-uat",                 "event": "PreToolCall", "description": "Confirms test execution reports and acceptance checklists are complete" },
    { "name": "terminology-drift-detector","event": "PostToolCall","description": "Cross-artifact scan for ubiquitous language inconsistencies" },
    { "name": "adr-conflict-detector",   "event": "PostToolCall", "description": "Checks new ADR against existing ADRs for conflicts or supersession" },
    { "name": "contract-compliance-checker","event": "PostToolCall","description": "Validates generated event schemas against existing consumer-driven contracts" },
    { "name": "security-gate",           "event": "PostToolCall", "description": "Flags security-sensitive artifacts for Security Reviewer agent" },
    { "name": "compliance-gate",         "event": "PostToolCall", "description": "Flags compliance-mapped artifacts for Compliance Assessor tracking" }
  ],

  "mcp": [
    { "name": "github", "description": "Repo creation, branch protection, PR templates, issue tracking for multi-repo management" },
    { "name": "git",    "description": "Local git operations, repo initialisation, branching per bounded context" }
  ]
}
